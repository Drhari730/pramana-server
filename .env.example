# ---- Pramana server environment ----
# Railway sets PORT and DATABASE_URL automatically when you add a Postgres plugin.

# REQUIRED: a long random secret for signing login sessions.
# Generate one: run  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=paste-a-long-random-string-here

# REQUIRED: your app's public URL (Railway gives you one, e.g. https://pramana-production.up.railway.app)
APP_URL=https://your-app.up.railway.app

# OPTIONAL: Google sign-in. Leave blank to use email+password only.
GOOGLE_CLIENT_ID=

# OPTIONAL: Brevo email (for invite emails). Leave blank and invites still work via copyable link.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-login@example.com
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM=Pramana <no-reply@yourdomain.com>

NODE_ENV=production
